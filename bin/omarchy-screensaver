#!/bin/bash

# omarchy:summary=Run the Omarchy screensaver using random effects from TTE.

screensaver_in_focus() {
  hyprctl activewindow -j | jq -e '.class == "org.omarchy.screensaver"' >/dev/null 2>&1
}

tte_pid=""

exit_screensaver() {
  hyprctl keyword cursor:invisible false &>/dev/null || true
  # Track the tte we spawned by PID instead of `pkill -x tte`, because on
  # NixOS the wrapped binary's comm is `.tte-wrapped` (truncated to 15
  # chars) so `-x tte` never matches. Without this fix the inner wait
  # loop below also fails immediately, the outer `while true` respawns
  # tte at hundreds of Hz, and the screensaver flickers as if multiple
  # are running.
  [ -n "$tte_pid" ] && kill "$tte_pid" 2>/dev/null
  pkill -f "\.tte-wrapped" 2>/dev/null || true
  pkill -x tte 2>/dev/null
  pkill -f org.omarchy.screensaver 2>/dev/null
  exit 0
}

# Exit the screensaver on signals and input from keyboard and mouse
trap exit_screensaver SIGINT SIGTERM SIGHUP SIGQUIT

printf '\033]11;rgb:00/00/00\007'  # Set background color to black

hyprctl keyword cursor:invisible true &>/dev/null

while true; do
  tte -i ~/.config/omarchy/branding/screensaver.txt \
    --frame-rate 120 --canvas-width 0 --canvas-height 0 --reuse-canvas --anchor-canvas c --anchor-text c\
    --random-effect --no-eol --no-restore-cursor &
  tte_pid=$!

  while kill -0 "$tte_pid" 2>/dev/null; do
    if read -n1 -t 1 || ! screensaver_in_focus; then
      exit_screensaver
    fi
  done
done
