#!/bin/bash

# omarchy:summary=Remove enrolled fingerprints
# omarchy:requires-sudo=true

set -e

# Nix deviation: PAM and package removal are declarative on NixOS.
# Set omarchy.fido2_auth.fingerprint_support = false; this script just
# unenrolls the user's prints. Omarchy 4: the omarchy-shell lock plugin
# stops offering fingerprint automatically once there are no enrolled prints.

remove_enrolled_prints() {
  if command -v fprintd-delete >/dev/null 2>&1; then
    if fprintd-list "$USER" 2>/dev/null | grep -q .; then
      echo "Deleting enrolled fingerprints for $USER..."
      sudo fprintd-delete "$USER" || true
    fi
  fi
}

echo -e "\e[32mRemoving fingerprint authentication.\n\e[0m"

remove_enrolled_prints

echo -e "\e[32mEnrolled fingerprints removed. Drop fprintd from your"
echo -e "NixOS config to fully disable the PAM stack.\e[0m"
