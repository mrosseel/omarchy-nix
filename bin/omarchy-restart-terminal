#!/bin/bash

# omarchy:summary=Reload supported terminal emulators after config changes

# Nix: alacritty.toml is a read-only home-manager symlink; only touch it when
# writable so the live-reload trigger doesn't error.
if [[ -w ~/.config/alacritty/alacritty.toml ]]; then
  touch ~/.config/alacritty/alacritty.toml
fi

# Nix: nixpkgs wrappers rename comm to .APP-wrapped, so pgrep -x / killall miss
# them. Signal by command-line pattern instead (matches APP and .APP-wrapped).
pkill -USR1 -f "(^|/)\.?kitty(-wrapped)?( |$)" 2>/dev/null || true
pkill -USR2 -f "(^|/)\.?ghostty(-wrapped)?( |$)" 2>/dev/null || true
